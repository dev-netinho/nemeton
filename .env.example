MARIADB_ROOT_PASSWORD=replace-with-a-long-random-secret
DB_NAME=nemeton
DB_USER=nemeton
DB_PASSWORD=replace-with-another-long-random-secret
RCON_PASSWORD=replace-with-a-third-long-random-secret
DISCORD_BOT_TOKEN=
TZ=America/Belem

# VPS beta profile. Keep this conservative while other projects share the host.
MC_VERSION=1.21.11
MC_IMAGE=itzg/minecraft-server:java25
MC_MEMORY=4G
MC_INIT_MEMORY=1G
MC_MEMORY_LIMIT=5G
MC_MAX_PLAYERS=15
MC_VIEW_DISTANCE=7
MC_SIMULATION_DISTANCE=5
DB_MEMORY_LIMIT=768M

# restic/rclone (optional off-site target)
RESTIC_REPOSITORY=/backups/restic
RESTIC_PASSWORD=replace-with-a-fourth-long-random-secret
RCLONE_REMOTE=
